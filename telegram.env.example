# Copy this file to /home/ubuntu/.config/lh-sh-crawler/telegram.env
# and set permissions to 600. Never commit the real token.
TELEGRAM_BOT_TOKEN=replace_with_botfather_token
TELEGRAM_CHAT_ID=replace_after_sending_start_to_the_bot
TELEGRAM_USER_ID=replace_after_sending_start_to_the_bot
MYHOME_API_SERVICE_KEY=replace_with_data_go_kr_service_key
HOUSING_USER_PROFILE_FILE=/home/ubuntu/.config/monitor-platform/housing-profile.json
REMINDER_AI_MODEL=gpt-5-mini

# Optional Google Calendar integration. Use a dedicated calendar and a separate
# Google OAuth client/refresh token. These values must never be committed.
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_ID=replace_with_dedicated_calendar_id
GOOGLE_OAUTH_CLIENT_ID=replace_with_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=replace_with_oauth_client_secret
GOOGLE_OAUTH_REFRESH_TOKEN=replace_with_refresh_token
GOOGLE_CALENDAR_SYNC_INTERVAL_MS=60000
