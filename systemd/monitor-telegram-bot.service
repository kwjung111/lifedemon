[Unit]
Description=Monitor platform Telegram gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/data/crawler
EnvironmentFile=/home/ubuntu/.config/monitor-platform/telegram.env
EnvironmentFile=-/home/ubuntu/.config/monitor-platform/openai-api.env
ExecStart=/usr/local/bin/node /data/crawler/src/bot.mjs
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
