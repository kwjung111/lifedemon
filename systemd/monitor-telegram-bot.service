[Unit]
Description=Monitor platform Telegram gateway
After=network-online.target
Wants=network-online.target
OnFailure=monitor-failure-notify@%n.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/data/crawler
EnvironmentFile=/home/ubuntu/.config/monitor-platform/telegram.env
EnvironmentFile=-/home/ubuntu/.config/monitor-platform/openai-api.env
Environment=CODEX_API_FALLBACK_ENABLED=true
Environment=CODEX_API_DAILY_CALL_LIMIT=10
ExecStart=/usr/local/bin/node --no-network-family-autoselection /data/crawler/src/bot.mjs
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
UMask=0077

[Install]
WantedBy=multi-user.target
