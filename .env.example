TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me
TELEGRAM_USER_ID=replace_me
MONITOR_DATA_DIR=./data
HOUSING_DATA_DIR=./data
JOB_DATA_DIR=./data
# Private, ignored files. Use absolute paths in production.
JOB_USER_PROFILE_FILE=./data/job-profile.json
# Company verification output refreshed from the configured JobPlanet account.
JOB_COMPANY_VERIFICATION_FILE=./data/company-verifications.json
JOBPLANET_STORAGE_STATE_FILE=./data/jobplanet-storage-state.json
JOBPLANET_ID=
JOBPLANET_PASSWORD=
# Wanted is discovered through non-interactive Codex live web search.
# The first run uses the server's ChatGPT-linked Codex login. A quota/auth failure
# may fall back to this API key (or OPENAI_API_KEY) when configured.
CODEX_BIN=/home/ubuntu/.local/bin/codex
CODEX_API_FALLBACK_KEY=
CODEX_API_FALLBACK_ENABLED=false
CODEX_API_DAILY_CALL_LIMIT=10
GMAIL_WANTED_ENABLED=false
GMAIL_WANTED_QUERY=label:"BOT/Wanted" newer_than:30d
GMAIL_OAUTH_REFRESH_TOKEN=
REMINDER_AI_MODEL=gpt-5-mini
# Life Inbox uses deterministic rules first and Codex only for ambiguous free text.
INBOX_AI_ENABLED=true

# Optional dedicated Google Calendar for bidirectional global-reminder sync.
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_ID=replace_with_dedicated_calendar_id
GOOGLE_OAUTH_CLIENT_ID=replace_with_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=replace_with_oauth_client_secret
GOOGLE_OAUTH_REFRESH_TOKEN=replace_with_refresh_token
GOOGLE_CALENDAR_SYNC_INTERVAL_MS=60000
